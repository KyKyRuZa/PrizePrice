{
  "name": "prizeprice-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "docker-start": "node src/index.js",
    "docker-build": "docker build -t prizeprice-server .",
    "docker-up": "docker compose up -d",
    "docker-down": "docker compose down",
    "docker-restart": "docker compose down && docker compose up -d --build",
    "watcher:start": "node src/scripts/start-price-watcher.js",
    "db:migrate": "node src/scripts/migrate.js",
    "preflight:ci": "node src/scripts/preflight-ci.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "load:price-watcher": "node src/scripts/load-price-watcher.js"
  },
  "dependencies": {
    "@sentry/node": "^9.47.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "sequelize": "^6.37.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/ui": "^2.1.8",
    "jsdom": "^25.0.1",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8",
    "yaml": "^2.8.1"
  }
}
